{
    "Version":"2012-10-17",		 	 	 
    "Statement": [
        {
            "Effect": "Deny",
            "Principal": "*",
            "Action": [
                "s3:*",
                "sts:*",
                "kms:*",
                "sqs:*",
                "secretsmanager:*",
                "cognito-identity:*",
                "cognito-idp:*",
                "cognito-sync:*",
                "logs:*",
                "dynamodb:*",
                "ecr:*",
                "aoss:*"
            ],
            "Resource": "*",
            "Condition": {
                "StringNotEqualsIfExists": {
                    "aws:SourceOrgID": "<my-org-id>",
                    "aws:SourceAccount": "<third-party-account-a>"
                },  
                "Null": {
                    "aws:SourceAccount": "false"
                },
                "Bool": {
                    "aws:PrincipalIsAWSService": "true"
                }
            }
        }
    ]
}
